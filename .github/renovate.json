{
  "extends": [
    "github>rancher/renovate-config#release"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "matchPackageNames": ["fedora"],
      "matchDatasources": ["docker"],
      "allowedVersions": "<42.0.0"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    }
  ]
}
